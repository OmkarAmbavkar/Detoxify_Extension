{
  "manifest_version": 3,
  "name": "Detoxify: AI Algorithm Harmonizer",
  "version": "1.0.0",
  "description": "Retrain your YouTube algorithm by auto-watching curated content.",
  "permissions": [
    "cookies",
    "tabs",
    "storage",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://googleapis.com/*",
    "https://www.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
